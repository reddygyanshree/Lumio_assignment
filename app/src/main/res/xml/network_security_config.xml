<?xml version="1.0" encoding="utf-8"?>
<!--
    - trust-anchors: fix "Trust anchor for certification path not found".
    - cleartextTrafficPermitted: many news image URLs are HTTP; allow them to load.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
